# ── Gateway de pagamento ──
# Valores aceitos: babylon | amplopay | enkibank | syncpay (padrão: babylon)
PAYMENT_GATEWAY=babylon

# Babylon
BABYLON_SECRET_KEY=
BABYLON_COMPANY_ID=
BABYLON_BASE_URL=https://api.bancobabylon.com/functions/v1
BABYLON_WEBHOOK_TOKEN=
BABYLON_WEBHOOK_CALLBACK_URL=

# AmploPay
AMPLOPAY_PUBLIC_KEY=
AMPLOPAY_SECRET_KEY=
AMPLOPAY_WEBHOOK_TOKEN=
AMPLOPAY_WEBHOOK_CALLBACK_URL=

# Enki Bank
ENKIBANK_PUBLIC_KEY=
ENKIBANK_SECRET_KEY=
ENKIBANK_WITHDRAW_KEY=
ENKIBANK_WEBHOOK_TOKEN=
ENKIBANK_WEBHOOK_CALLBACK_URL=

# Sync Payments
SYNCPAY_CLIENT_ID=
SYNCPAY_CLIENT_SECRET=
SYNCPAY_WEBHOOK_CALLBACK_URL=

# Servidor
BABYLON_PROXY_PORT=8787
# Origens permitidas (CORS). Precisa ser APENAS o domínio (sem /checkout-mensal etc).
# Separe múltiplos por vírgula.
BABYLON_ALLOWED_ORIGINS=https://combosalvauniversitario.site,https://app.combosalvauniversitario.site
BABYLON_PROXY_REQUIRE_AUTH=true
NODE_ENV=production
PUBLIC_APP_URL=https://combosalvauniversitario.site

# Supabase (server-side)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Frontend (apenas se buildar frontend no mesmo servidor)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_BABYLON_PROXY_URL=

# ── WhatsApp via Baileys (direto, gratuito) ──
# Se WHATSAPP_PAIRING_PHONE_NUMBER estiver preenchido, o servidor gera código de pareamento.
# Senão, usa QR code como fallback.
WHATSAPP_ENABLED=false
WHATSAPP_PAIRING_PHONE_NUMBER=
WHATSAPP_AUDIO_URL=

# Meta Conversions API (server-side pixel)
META_PIXEL_ID=1665717361520339
META_CAPI_ACCESS_TOKEN=
