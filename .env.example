VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_BABYLON_PROXY_URL=

BABYLON_SECRET_KEY=
BABYLON_COMPANY_ID=
BABYLON_BASE_URL=https://api.bancobabylon.com/functions/v1
BABYLON_PROXY_PORT=8787
BABYLON_WEBHOOK_TOKEN=
# Origens permitidas (CORS). Precisa ser APENAS o domínio (sem paths). Separe por vírgula.
BABYLON_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5500,http://127.0.0.1:5500,https://combosalvauniversitario.site,https://app.combosalvauniversitario.site
BABYLON_PROXY_REQUIRE_AUTH=false
NODE_ENV=development

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# E-mails transacionais do checkout público (via Resend)
# Coloque os valores reais apenas no .env local. Nao salve chaves reais neste arquivo de exemplo.
CHECKOUT_EMAILS_ENABLED=false
CHECKOUT_EMAIL_PROVIDER=resend
CHECKOUT_EMAIL_FROM=Sua Marca <email@seudominio.com>
CHECKOUT_EMAIL_REPLY_TO=
CHECKOUT_EMAIL_BCC=
CHECKOUT_EMAIL_BRAND_NAME=Combo Salva Universitario
CHECKOUT_EMAIL_ASSET_BASE_URL=
CHECKOUT_EMAIL_LOGO_URL=
CHECKOUT_EMAIL_HERO_URL=
CHECKOUT_EMAIL_BADGE_URL=
CHECKOUT_EMAIL_TESTIMONIAL_URL=
CHECKOUT_EMAIL_PRIMARY_CTA_URL=
CHECKOUT_EMAIL_SUPPORT_URL=
RESEND_API_KEY=

# WhatsApp via Baileys (direto, gratuito) — mensagem + áudio no pagamento aprovado
# Se WHATSAPP_PAIRING_PHONE_NUMBER estiver preenchido, o servidor gera código de pareamento.
# Senão, usa QR code como fallback.
WHATSAPP_ENABLED=false
WHATSAPP_PAIRING_PHONE_NUMBER=
WHATSAPP_AUDIO_URL=

# Meta Conversions API (server-side pixel)
META_PIXEL_ID=1665717361520339
META_CAPI_ACCESS_TOKEN=
