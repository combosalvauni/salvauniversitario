{
  "name": "concursaflix",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:babylon": "node server/babylonProxy.mjs",
    "env:check": "powershell -ExecutionPolicy Bypass -File ./scripts/check_local_env.ps1",
    "homepage:status": "powershell -ExecutionPolicy Bypass -File ./scripts/vps_guard.ps1 -Profile Homepage -Mode Status",
    "homepage:sync": "powershell -ExecutionPolicy Bypass -File ./scripts/vps_guard.ps1 -Profile Homepage -Mode Sync",
    "homepage:deploy": "powershell -ExecutionPolicy Bypass -File ./scripts/vps_guard.ps1 -Profile Homepage -Mode Deploy",
    "homepage:deploy:force": "powershell -ExecutionPolicy Bypass -File ./scripts/vps_guard.ps1 -Profile Homepage -Mode Deploy -Force",
    "checkout:status": "powershell -ExecutionPolicy Bypass -File ./scripts/vps_guard.ps1 -Profile CheckoutAll -Mode Status",
    "checkout:sync": "powershell -ExecutionPolicy Bypass -File ./scripts/vps_guard.ps1 -Profile CheckoutAll -Mode Sync",
    "checkout:deploy": "powershell -ExecutionPolicy Bypass -File ./scripts/vps_guard.ps1 -Profile CheckoutAll -Mode Deploy",
    "checkout:deploy:force": "powershell -ExecutionPolicy Bypass -File ./scripts/vps_guard.ps1 -Profile CheckoutAll -Mode Deploy -Force",
    "backend:status": "powershell -ExecutionPolicy Bypass -File ./scripts/vps_guard.ps1 -Profile Backend -Mode Status",
    "backend:sync": "powershell -ExecutionPolicy Bypass -File ./scripts/vps_guard.ps1 -Profile Backend -Mode Sync",
    "backend:deploy": "powershell -ExecutionPolicy Bypass -File ./scripts/vps_guard.ps1 -Profile Backend -Mode Deploy",
    "backend:deploy:force": "powershell -ExecutionPolicy Bypass -File ./scripts/vps_guard.ps1 -Profile Backend -Mode Deploy -Force",
    "env:vps:status": "powershell -ExecutionPolicy Bypass -File ./scripts/vps_guard.ps1 -Profile VpsEnv -Mode Status",
    "env:vps:sync": "powershell -ExecutionPolicy Bypass -File ./scripts/vps_guard.ps1 -Profile VpsEnv -Mode Sync",
    "env:vps:deploy": "powershell -ExecutionPolicy Bypass -File ./scripts/vps_guard.ps1 -Profile VpsEnv -Mode Deploy",
    "env:vps:deploy:force": "powershell -ExecutionPolicy Bypass -File ./scripts/vps_guard.ps1 -Profile VpsEnv -Mode Deploy -Force",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "admin:setup": "node create_admin_user.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.95.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.564.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1"
  }
}
